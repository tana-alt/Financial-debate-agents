#!/usr/bin/env sh
set -eu

fail() {
  echo "pre-push policy: $*" >&2
  exit 2
}

PRIMARY_BRANCH="${FOUNDATION_PRIMARY_BRANCH:-main}"

while read -r _local_ref _local_oid remote_ref _remote_oid; do
  case "$remote_ref" in
    "refs/heads/$PRIMARY_BRANCH"|refs/heads/main|refs/heads/master|"$PRIMARY_BRANCH"|main|master)
      fail "direct push to $remote_ref is blocked; push an owned agent/* branch and open a PR"
      ;;
  esac
done

ROOT="$(git rev-parse --show-toplevel)"
"$ROOT/scripts/check-agent-worktree-policy.sh"

cd "$ROOT"
# Git hooks export local repository variables. Clear them before running tests
# that create and inspect independent temporary Git repositories.
# shellcheck disable=SC2046
unset $(git rev-parse --local-env-vars)
make check-foundation
