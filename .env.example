# LLM provider: "fake", "anthropic", or "openai"
LLM_PROVIDER=anthropic

# Required only when using the matching real LLM provider.
# Leave both empty when LLM_PROVIDER=fake.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model names (optional; sensible defaults are used if blank)
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-5.4-mini

# SEC EDGAR requires a user-agent
SEC_USER_AGENT="Your Name your.email@example.com"

# Log level: DEBUG / INFO / WARNING
LOG_LEVEL=INFO

# CLI/API local defaults
EARNINGS_DEBATE_API_HOST=127.0.0.1
EARNINGS_DEBATE_API_PORT=8000
EARNINGS_DEBATE_API_URL=http://127.0.0.1:8000
EARNINGS_DEBATE_OUTPUT_DIR=outputs
EARNINGS_DEBATE_API_REQUEST_TIMEOUT_SECONDS=300

# LLM call defaults
EARNINGS_DEBATE_LLM_DEFAULT_MAX_TOKENS=2048
EARNINGS_DEBATE_LLM_DEFAULT_TEMPERATURE=0.7
EARNINGS_DEBATE_OPENAI_MIN_COMPLETION_TOKENS=4096

# Agent/runtime tunables
EARNINGS_DEBATE_AGENT_MAX_TOKENS=8192
EARNINGS_DEBATE_DEBATE_MAX_TOKENS=8192
EARNINGS_DEBATE_JUDGE_MAX_TOKENS=12000
EARNINGS_DEBATE_AGENT_TEMPERATURE=0.2
EARNINGS_DEBATE_JUDGE_TEMPERATURE=0.1
EARNINGS_DEBATE_AGENT_MAX_RETRIES=1
EARNINGS_DEBATE_AGENT_MAX_WORKERS=
EARNINGS_DEBATE_DEBATE_SELECTION_ATTEMPTS=2
EARNINGS_DEBATE_JUDGE_SELECTION_ATTEMPTS=2

# Acquisition/network/cache defaults
EARNINGS_DEBATE_SEC_REQUEST_TIMEOUT_SECONDS=30
EARNINGS_DEBATE_SEC_FILING_CACHE_DIR=samples/cache
EARNINGS_DEBATE_SEC_CACHE_KEY_LENGTH=12
EARNINGS_DEBATE_MAX_DOCUMENT_SECTION_CHARS=8000

# Existing report quality gates
EARNINGS_DEBATE_REQUIRE_GUIDANCE=1
EARNINGS_DEBATE_REQUIRE_NUMERIC_GROUNDING=1
